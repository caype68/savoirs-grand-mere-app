{
  "expo": {
    "name": "Savoirs de Grand-Mère",
    "slug": "savoirs-de-grand-mere",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/grandmere.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0D10",
    "splash": {
      "image": "./assets/logo/grandmere.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0D10"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.savoirsdegrandmere.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Cette application n'utilise pas la caméra.",
        "NSPhotoLibraryUsageDescription": "Pour exporter vos favoris."
      }
    },
    "android": {
      "package": "com.savoirsdegrandmere.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0A0D10",
        "foregroundImage": "./assets/logo/grandmere.png"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/logo/grandmere.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "63762c99-fd3c-4136-a4d0-f421d6360cf2"
      }
    },
    "plugins": [
      "expo-sharing",
      "expo-sqlite"
    ]
  }
}
